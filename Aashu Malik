        }

        .btn {
            display: inline-block;
            padding: 12px 25px;
            background: #ff4b2b;
            color: white;
            text-decoration: none;
            border-radius: 25px;
            margin-top: 15px;
            transition: 0.3s;
        }

        .btn:hover {
            background: #ff416c;
            transform: scale(1.05);
        }

        footer {
            padding: 20px;
            font-size: 0.9rem;
