    <style>
        /* CSS: Website ka Design */
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #1a1a1a; /* Dark Theme */
            color: white;
            text-align: center;
